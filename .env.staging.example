APP_NAME=Sibedas-Staging
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://sibedas-staging.aureonforge.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sibedas_staging
DB_USERNAME=sibedas_staging
DB_PASSWORD=__SET_ON_SERVER__

# Use a separate cache namespace to avoid colliding with prod sibedas
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE=sibedas_staging_session

# Cache: file driver acceptable for staging (low traffic)
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file
CACHE_PREFIX=sibedas_staging_

# Mail: keep noop for staging (Bapenda staff don't need email notifications during pilot)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="staging-noreply@aureonforge.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=sibedas-staging.aureonforge.com

# Vite
VITE_APP_NAME="${APP_NAME}"
VITE_APP_HOST=sibedas-staging.aureonforge.com

# Sentry — set when ready
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_TRACES_SAMPLE_RATE=0.1

# Webhook secret for auto-deploy (rotate from prod's value!)
WEBHOOK_SECRET=__SET_ON_SERVER__
